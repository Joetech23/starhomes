# Supabase — Star Homes project (Care Access Nigeria org)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# Canonical site URL used for SEO (metadataBase, sitemap, canonical/OG URLs)
NEXT_PUBLIC_SITE_URL=https://starhomes-eta.vercel.app

# AI chatbot — Anthropic API key (SERVER-SIDE SECRET; do NOT commit or prefix with NEXT_PUBLIC).
# Set it in Vercel → Settings → Environment Variables, and in .env.local for local dev.
# Without it, the chat widget shows a friendly "contact us on WhatsApp" fallback.
ANTHROPIC_API_KEY=sk-ant-xxx
